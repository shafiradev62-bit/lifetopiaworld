# Solana — Public Alpha is Devnet-only. Use ONE mint for LFG + utility/boost checks:
# VITE_LIFETOPIA_ALPHA_MINT=<devnet_mint>
# Or set any one of these (same value); priority is ALPHA → TOKEN → ALPHA_NFT → DEVNET_TOKEN
VITE_LIFETOPIA_ALPHA_MINT=
VITE_TOKEN_MINT_ADDRESS=
VITE_ALPHA_NFT_MINT=
VITE_DEVNET_TOKEN_MINT=
VITE_SOLANA_DEVNET_RPC=https://api.devnet.solana.com
# Optional: treasury JSON key array for server-side mint to players (see devnetTransactions)
VITE_LFG_TREASURY_KEY=

# Wallet deep-link (REQUIRED for mobile wallet connect on HTTPS deployment)
# Set this to your deployed Railway URL, e.g. https://lifetopia-app.up.railway.app
VITE_WALLET_DAPP_URL=https://your-app.railway.app
